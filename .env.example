# Copy to .env and fill in real values. .env is gitignored — never commit real
# credentials. Only vars actually needed for `make pipeline-stock` (bomVerifier
# providers that require auth) are listed; lcsc/chipdip need no credentials.

# DigiKey Product Information API v4 (client-credentials OAuth) — required for -digikey=...
DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=

# office.promelec.ru (PROM2PROM) partner account — required for -promelec=...
PROMELEC_LOGIN=
PROMELEC_PASSWORD=
